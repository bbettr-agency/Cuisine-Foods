# Cuisine Foods — environment variables
# Copy to .env.local for local dev; set the real values in Vercel (never commit .env).

# GoHighLevel inbound webhook that receives quote/collection enquiries.
# The contact/quote form POSTs the lead payload here.
GHL_WEBHOOK_URL=

# Public site URL (used for canonical URLs, sitemap, OG tags).
NEXT_PUBLIC_SITE_URL=https://cuisinefoods.co.za
